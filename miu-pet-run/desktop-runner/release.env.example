# Copy to release.env and edit for Developer ID releases.

PRODUCT_NAME="猫小伴"
APP_BUNDLE_ID="com.zhanghz.maoxiaoban"

# Use "-" for local ad-hoc signing.
# Use a real identity for public release, for example:
# SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
SIGN_IDENTITY="-"

# Required only for notarization.
# Create once with:
# xcrun notarytool store-credentials "maoxiaoban-notary" --apple-id "you@example.com" --team-id "TEAMID" --password "app-specific-password"
NOTARY_PROFILE="maoxiaoban-notary"

# Set to 1 for public release notarization.
# The release script submits the DMG when notarization is enabled.
NOTARIZE="0"
